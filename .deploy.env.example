# =============================================================================
# HYVE Deploy Configuration — fill in your values and save as .deploy.env
# This file is gitignored. Never commit .deploy.env.
# =============================================================================

# EC2 connection string: ec2-user@<public-ip-or-hostname>
EC2_HOST=ec2-user@<your-ec2-public-ip>

# Absolute path to your .pem key file
SSH_KEY=/path/to/your-key.pem
