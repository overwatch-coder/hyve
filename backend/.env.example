# =============================================================================
# HYVE Backend — Local Development Environment
# =============================================================================
# Copy this file: cp backend/.env.example backend/.env
# Fill in real values. Never commit backend/.env (it's in .gitignore).
# =============================================================================

# --- AI Provider ---
# Choose "openai" or "gemini". Controls both LLM calls and the embedding model.
# Only fill in the key for the provider you chose — leave the other blank.
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key          # get one free at: https://aistudio.google.com

# --- Database ---
# SQLite (zero setup, good for local dev):
DATABASE_URL=sqlite:///hyvedb.sqlite3
# PostgreSQL (if you run Postgres locally):
# DATABASE_URL=postgresql://hyve:hyvepass@localhost:5432/hyve

# --- Redis ---
# Required for background task queuing and embedding cache.
# Install Redis locally or use a free cloud plan (Upstash, Redis Cloud).
# If not set, Redis features degrade gracefully (no caching, no async tasks).
REDIS_URL=redis://localhost:6379/0
EMBEDDING_CACHE_REDIS_URL=redis://localhost:6379/1

# --- Canopy API ---
# Required for /amazon/* endpoints (product search and reviews).
# Get your key at: https://canopyapi.co
CANOPY_API_KEY=your-canopy-api-key

# --- Admin Authentication ---
# ADMIN_PASSWORD: used to log in at /admin/login
# JWT_SECRET: signs admin JWT tokens — any long random string works for local dev
ADMIN_PASSWORD=localdevpassword
JWT_SECRET=local-dev-jwt-secret-change-this-in-production

# --- URLs ---
# FRONTEND_URL: added to CORS allowed origins
# BACKEND_URL: used to build public image URLs in API responses
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Deployment Settings ---
USE_CELERY=false
