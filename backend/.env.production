OPENAI_API_KEY=your_openai_api_key
LLM_PROVIDER="openai" # openai | gemini
REDIS_URL=redis://redis:6379/0
# hyvepass must be replaced with the same value as POSTGRES_PASSWORD below
DATABASE_URL=postgresql://hyve:hyvepass@db:5432/hyve
ADMIN_PASSWORD=set_admin_password
JWT_SECRET="hyve_jwt_secret_key_2026_change_in_production"
FRONTEND_URL="http://localhost:3000"
CANOPY_API_KEY="your_canopy_api_key" # go to: https://rest.canopyapi.co/ and proceed from there
BACKEND_URL="http://localhost:8000"
HF_TOKEN="your_hugging_face_token" # go to: https://huggingface.co/settings/tokens/new

# --- PostgreSQL Docker service credentials ---
# These are read by the db container directly.
# POSTGRES_PASSWORD must match the password used in DATABASE_URL above.
POSTGRES_USER=hyve
POSTGRES_PASSWORD=<choose-a-strong-db-password>
POSTGRES_DB=hyve
