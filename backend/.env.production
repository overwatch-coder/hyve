# ---------------------------------------------------------------
# PostgreSQL credentials — used by BOTH the db container and the
# backend. Set POSTGRES_PASSWORD once here; copy the same value
# into DATABASE_URL below. They MUST be identical.
# ---------------------------------------------------------------
POSTGRES_USER=hyve
POSTGRES_PASSWORD=<choose-a-strong-db-password>
POSTGRES_DB=hyve

# DATABASE_URL — replace <same-as-POSTGRES_PASSWORD> with the value
# you set above. The two passwords must always match.
DATABASE_URL=postgresql://hyve:<same-as-POSTGRES_PASSWORD>@db:5432/hyve

# Redis
REDIS_URL=redis://redis:6379/0
EMBEDDING_CACHE_REDIS_URL=redis://redis:6379/1

# OpenAI — required for AI pipeline
OPENAI_API_KEY=<your-openai-api-key>
LLM_PROVIDER=openai

# Canopy API (canopyapi.co) — required for /amazon/* product search endpoints
CANOPY_API_KEY=<your-canopy-api-key>

# Hugging Face token (optional, for private models)
HF_TOKEN=<your-hugging-face-token>

# Admin auth — use strong random values in production
ADMIN_PASSWORD=<choose-a-strong-admin-password>
JWT_SECRET=<random-64-char-string-replace-before-deploying>

# URLs — set both to http://<ec2-public-ip> after the instance is running
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Deployment mode — keep these values for AWS Docker deployment
USE_CELERY=false
WARM_EMBEDDING_MODEL=1
