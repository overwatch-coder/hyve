# =============================================================================
# HYVE Production Environment — AWS EC2 Docker Deployment
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp backend/.env.production backend/.env
# 2. Fill in every <placeholder> with real values
# 3. Never commit backend/.env (it's in .gitignore)
# =============================================================================

# --- PostgreSQL credentials ---
# Used by BOTH the db container and the backend service (via env_file).
# Set POSTGRES_PASSWORD once here; copy the same value into DATABASE_URL below.
# They MUST be identical — if they diverge the backend cannot connect.
POSTGRES_USER=hyve
POSTGRES_PASSWORD=<choose-a-strong-db-password>
POSTGRES_DB=hyve

# DATABASE_URL — replace <same-as-POSTGRES_PASSWORD> with the exact value
# you chose for POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://hyve:<same-as-POSTGRES_PASSWORD>@db:5432/hyve

# --- Redis ---
# Docker Redis service — uses Docker service name "redis" as hostname
REDIS_URL=redis://redis:6379/0
EMBEDDING_CACHE_REDIS_URL=redis://redis:6379/1

# --- AI Provider ---
# Set LLM_PROVIDER to "openai" or "gemini". This controls both the LLM calls
# and the embedding model used for clustering.
#
# If LLM_PROVIDER=openai — fill in OPENAI_API_KEY; leave GEMINI_API_KEY blank.
# If LLM_PROVIDER=gemini — fill in GEMINI_API_KEY; leave OPENAI_API_KEY blank.
LLM_PROVIDER=openai
OPENAI_API_KEY=<your-openai-api-key>
GEMINI_API_KEY=<your-gemini-api-key>

# --- Canopy API ---
# Required for /amazon/* endpoints (product search, reviews, categories)
# Get your key at: https://canopyapi.co
CANOPY_API_KEY=<your-canopy-api-key>

# --- Admin Authentication ---
# ADMIN_PASSWORD: used to log in at /admin/login
# JWT_SECRET: signs admin JWT tokens — generate with: openssl rand -hex 32
ADMIN_PASSWORD=<choose-a-strong-admin-password>
JWT_SECRET=<random-64-char-string-generate-with-openssl-rand-hex-32>

# --- URLs ---
# Set both to http://<your-ec2-public-ip> (no trailing slash)
# Find your public IP in the AWS EC2 console after the instance is running.
# FRONTEND_URL: added to CORS allowed origins
# BACKEND_URL: used to build public image URLs (e.g., http://<ip>/static/product-images/...)
FRONTEND_URL=http://<ec2-public-ip>
BACKEND_URL=http://<ec2-public-ip>

# --- Deployment Settings ---
USE_CELERY=false
