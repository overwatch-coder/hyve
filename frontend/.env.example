# =============================================================================
# HYVE Frontend — Local Development Environment
# =============================================================================
# Copy this file: cp frontend/.env.example frontend/.env
# For local dev (without Docker), point both vars to the FastAPI backend.
# For Docker deployment, both vars are baked into the image as /api (see Dockerfile).
# =============================================================================

# Base URL used by Axios (src/lib/api.ts) for all REST API calls.
VITE_API_BASE_URL=http://localhost:8000

# URL used by EventSource (src/pages/Explore.tsx) for SSE streaming.
VITE_API_URL=http://localhost:8000
