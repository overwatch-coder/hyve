VITE_API_BASE_URL=your_backend_api_base_url
# Base URL used by Axios (src/lib/api.ts) for all REST API calls.
# In the single-origin Docker deployment Nginx proxies /api/ → FastAPI, so set this to /api.

VITE_API_URL=your_backend_api_url
# URL used by EventSource (src/pages/Explore.tsx) for SSE streaming.
# Typically the same value as VITE_API_BASE_URL (e.g. /api).
